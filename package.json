{
  "name": "numberlink-game",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend:start": "docker-compose -f mock-api/docker-compose.yml up -d",
    "backend:stop": "docker-compose -f mock-api/docker-compose.yml down",
    "devtools": "npx remotedev --port 8000",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@redux-devtools/extension": "^3.3.0",
    "@reduxjs/toolkit": "^2.11.2",
    "expo": "~55.0.5",
    "expo-crypto": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-redux": "^9.2.0",
    "remote-redux-devtools": "^0.5.16"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
